# Gnuplot style for IEEE S&P paper figures
set style line 1 lc rgb '#2166ac' lt 1 lw 2 pt 7 ps 0.8
set style line 2 lc rgb '#b2182b' lt 1 lw 2 pt 5 ps 0.8
set style line 3 lc rgb '#1b7837' lt 1 lw 2 pt 9 ps 0.8
set style line 4 lc rgb '#762a83' lt 1 lw 2 pt 11 ps 0.8
set style line 5 lc rgb '#e08214' lt 1 lw 2 pt 13 ps 0.8

set border 3
set tics nomirror
set grid ytics lt 0 lw 0.5 lc rgb "#cccccc"
set key top left Left reverse samplen 2
